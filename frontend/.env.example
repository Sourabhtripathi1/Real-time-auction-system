# ────────────────────────────────────────────────────────────
# Frontend Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Note: All variables MUST be prefixed with VITE_ to be
# accessible in the browser via import.meta.env.VITE_*
# ────────────────────────────────────────────────────────────

# Backend REST API base URL (include /api suffix)
VITE_API_URL=http://localhost:5000/api

# Backend Socket.IO server URL (NO /api suffix)
VITE_SOCKET_URL=http://localhost:5000
