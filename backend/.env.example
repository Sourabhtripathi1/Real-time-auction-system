# ────────────────────────────────────────────────────────────
# Backend Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB
# Local:  mongodb://127.0.0.1:27017/auction-system
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/auction-system
MONGO_URI=mongodb://127.0.0.1:27017/auction-system

# JWT — CHANGE THIS TO A STRONG RANDOM SECRET IN PRODUCTION
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRES_IN=7d

# CORS — Frontend origin
CLIENT_URL=http://localhost:5173
