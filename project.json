  "edge_cases": [
    {
      "case": "Stale JWT bypass",
      "problem": "JWT still valid after user block/suspend",
      "solution": "authMiddleware fresh DB fetch on every request + socket io.use()",
      "files": ["authMiddleware.js", "socketHandler.js"],
      "http_code": 403
    },
    {
      "case": "Concurrent bid race condition",
      "problem": "Two bids placed instantly override each other",
      "solution": "findOneAndUpdate with $lt + $expr atomic guard. Returns 409 Conflict. UI auto-updates input.",
      "files": ["bidController.js", "useBid.js"],
      "http_code": 409
    },
    {
      "case": "Ghost socket connections",
      "problem": "Memory leak from unclosed sockets",
      "solution": "userRooms Map tracks all rooms per socket. Comprehensive disconnect cleanup. viewerUpdate on leave. pingTimeout: 20s.",
      "files": ["socketHandler.js"]
    },
    {
      "case": "Blocked user mid-session",
      "problem": "User still browsing while blocked",
      "solution": "authMiddleware rejects all requests. Socket disconnected at handshake. BlockedNotice shown.",
      "files": ["authMiddleware.js", "socket.js", "BlockedNotice.jsx"],
      "http_code": 403
    },
    {
      "case": "Seller suspended after active socket",
      "problem": "Can still act in room",
      "solution": "socket io.use() checks isBlocked on connect. placeBid re-validates user from DB.",
      "files": ["socketHandler.js"]
    },
    {
      "case": "Token reuse after logout",
      "problem": "Stolen token still works",
      "solution": "TokenBlacklist with SHA-256 hash + TTL index. Checked in both HTTP + socket auth.",
      "files": ["TokenBlacklist.js", "authMiddleware.js"],
      "http_code": 401
    },
    {
      "case": "Session expiry mid-use",
      "problem": "JWT expires while typing form",
      "solution": "tokenExpiresAt checked before every request. 5-min warning. auth:expired auto-logout.",
      "files": ["AuthContext.jsx", "authApi.js"],
      "http_code": 401
    },
    {
      "case": "File upload abuse",
      "problem": "Malicious payload via extension spoofing",
      "solution": "Multer: 5MB limit, 5 files max, mimetype + extension check, filename sanitization.",
      "files": ["multer.js"],
      "http_code": 400
    },
    {
      "case": "Bid input conflict",
      "problem": "User bid immediately outdated by other bid",
      "solution": "409 response auto-refetches auction, updates input minimum, shows friendly toast.",
      "files": ["useBid.js", "AuctionRoom.jsx"],
      "http_code": 409
    }
  ],
